---
---
<header id="main-header" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[92%] max-w-5xl flex justify-between items-center px-6 sm:px-8 py-3 rounded-full transition-all duration-300 bg-surface/50 border border-outline-variant/20 backdrop-blur-xl shadow-soft">
  <div class="text-2xl font-extrabold tracking-tighter text-primary">
    Cortez Web
  </div>
  <nav class="hidden md:flex gap-md font-label-md text-label-md">
    <a class="text-primary font-bold border-b-2 border-primary pb-1 transition-all hover:opacity-80 active:scale-95 cursor-pointer" href="#servicios">Servicios</a>
    <a class="text-on-surface-variant hover:text-primary transition-all duration-200 hover:opacity-80 active:scale-95 cursor-pointer" href="#portafolio">Portafolio</a>
    <a class="text-on-surface-variant hover:text-primary transition-all duration-200 hover:opacity-80 active:scale-95 cursor-pointer" href="#blog">Blog</a>
    <a class="text-on-surface-variant hover:text-primary transition-all duration-200 hover:opacity-80 active:scale-95 cursor-pointer" href="#contacto">Contacto</a>
  </nav>
  <div class="hidden md:block">
    <a href="#contacto" class="bg-primary-container text-on-primary font-label-md text-label-md px-6 py-2.5 rounded-full hover:bg-primary transition-colors shadow-soft cursor-pointer active:scale-98 text-center inline-block">
      Let's Talk
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.remove('bg-surface/50', 'py-3');
      header?.classList.add('bg-surface/85', 'py-2.5', 'shadow-md');
    } else {
      header?.classList.remove('bg-surface/85', 'py-2.5', 'shadow-md');
      header?.classList.add('bg-surface/50', 'py-3', 'shadow-soft');
    }
  });
</script>
