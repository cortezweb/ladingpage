---
const industries = [
  {
    name: "Aplicaciones Empresariales",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
      <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
    </svg>`
  },
  {
    name: "Fintech & Finanzas",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" />
      <path d="M12 6v12M15 9.5a2.5 2.5 0 0 0-5 0v5a2.5 2.5 0 0 0 5 0" />
    </svg>`
  },
  {
    name: "Salud & Medicina",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
    </svg>`
  },
  {
    name: "E-Commerce & Comercio",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0" />
    </svg>`
  },
  {
    name: "Inmobiliaria & Bienes Raíces",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z" />
      <path d="M9 11l3-3 3 3v4H9v-4z" stroke-linejoin="round" />
    </svg>`
  },
  {
    name: "Deportes",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6M18 9h1.5a2.5 2.5 0 0 0 0-5H18M4 22h16M10 14.66V17c0 .55-.45 1-1 1H8v2h8v-2h-1c-.55 0-1-.45-1-1v-2.34M12 2a6 6 0 0 1 6 6v3a6 6 0 0 1-12 0V8a6 6 0 0 1 6-6z" />
    </svg>`
  },
  {
    name: "Fitness & Bienestar",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M18 4h3v16h-3zM3 4h3v16H3zM6 12h12" />
      <path d="M8 8h2v8H8zm6 0h2v8h-2z" />
    </svg>`
  },
  {
    name: "Logística & Transporte",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <rect x="1" y="3" width="15" height="13" rx="2" />
      <polygon points="16 8 20 8 23 11 23 16 16 16" />
      <circle cx="5.5" cy="18.5" r="2.5" />
      <circle cx="18.5" cy="18.5" r="2.5" />
    </svg>`
  },
  {
    name: "Turismo & Viajes",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <rect x="3" y="8" width="18" height="12" rx="2" />
      <path d="M8 8V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v3M9 12h6M12 12v6" />
    </svg>`
  },
  {
    name: "Educación & E-Learning",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M22 10v6M2 10l10-5 10 5-10 5zm0 0v5c0 2 2 3 6 3s6-1 6-3v-5" />
    </svg>`
  },
  {
    name: "Aviación",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M21 16V8a2 2 0 0 0-2-2h-4l-3-4H8l2 4H5L3 6v4l3 2-3 2v4l2-2h5l-2 4h4l3-4h4a2 2 0 0 0 2-2z" />
    </svg>`
  },
  {
    name: "Entretenimiento & Medios",
    icon: `<svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <rect x="2" y="8" width="20" height="12" rx="2" />
      <path d="M2 8l4-4h3l-4 4M7 8l4-4h3l-4 4M12 8l4-4h3l-4 4M17 8l4-4h1v4" />
      <path d="M2 8h20" />
    </svg>`
  }
];
---

<section class="py-section-gap bg-surface" id="industrias">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto space-y-4 animate-fade-in">
      <span class="text-xs font-bold uppercase tracking-wider text-primary">INDUSTRIAS</span>
      <h2 class="font-headline-xl text-headline-xl text-on-surface">
        <span class="gradient-text">Impulsando la Transformación</span> en Diversas Industrias.
      </h2>
    </div>

    <!-- Big Box with Pills Grid -->
    <div class="bg-surface-bright border border-outline-variant/30 rounded-3xl p-8 sm:p-10 shadow-soft animate-fade-in">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {industries.map((ind) => (
          <div class="bg-surface-container/30 border border-outline-variant/15 rounded-xl px-5 py-4 flex items-center gap-4 hover:shadow-soft hover:-translate-y-0.5 hover:border-primary/30 transition-all duration-200 cursor-default select-none group">
            <!-- Icon Wrapper -->
            <div class="group-hover:scale-105 transition-transform duration-200">
              <Fragment set:html={ind.icon} />
            </div>
            <!-- Name -->
            <span class="text-sm font-semibold text-on-surface-variant group-hover:text-primary transition-colors text-left leading-tight">
              {ind.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
