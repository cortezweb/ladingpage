---

<section class="py-section-gap px-gutter bg-[#0b1c30] text-white relative overflow-hidden rounded-3xl my-12" id="technologies">
  <!-- Sutil gradiente de fondo para imitar la esquina superior derecha verde, pero en azul/indigo -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/20 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary-container/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-container mx-auto relative z-10">
    <!-- Encabezado -->
    <div class="text-center mb-12">
      <span class="font-label-md text-label-md text-primary-fixed-dim tracking-widest uppercase block mb-3">TECNOLOGÍAS</span>
      <h2 class="font-headline-xl text-headline-xl text-white max-w-3xl mx-auto leading-tight">
        <span class="text-primary-fixed-dim">Experiencia Tecnológica</span> Profunda
        <br class="hidden md:block" />
        que Impulsa la Innovación Real
      </h2>
    </div>

    <!-- Pestañas (Tabs) de Categorías -->
    <div class="flex justify-start lg:justify-center overflow-x-auto pb-4 mb-12 gap-3 scrollbar-hide -mx-6 px-6 lg:mx-0 lg:px-0">
      {categories.map((cat, index) => (
        <button
          type="button"
          data-category-tab={cat.id}
          class={`px-6 py-3 rounded-full font-label-md text-label-md whitespace-nowrap transition-all duration-300 border cursor-pointer ${
            index === 0
              ? "bg-white text-[#0b1c30] border-white font-bold shadow-soft"
              : "bg-[#0b1c30]/40 text-on-primary-container/80 border-outline-variant/20 hover:border-white/50 hover:text-white"
          }`}
        >
          {cat.name}
        </button>
      ))}
    </div>

    <!-- Contenedor de Grillas de Tecnologías -->
    <div class="relative min-h-[220px]">
      {Object.entries(technologies).map(([catId, techList], index) => (
        <div
          data-tech-content={catId}
          class={`grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 transition-all duration-500 ${
            index === 0
              ? "opacity-100 scale-100 pointer-events-auto"
              : "opacity-0 scale-95 pointer-events-none absolute inset-0"
          }`}
        >
          {techList.map(tech => (
            <div class="flex flex-col items-center justify-center bg-[#071324]/60 border border-outline-variant/10 rounded-2xl p-8 hover:border-primary-fixed-dim/40 hover:bg-[#071324]/90 transition-all duration-300 group">
              <div class="mb-4 transform group-hover:scale-110 transition-transform duration-300" set:html={tech.svg} />
              <span class="font-label-md text-label-md text-on-primary-container group-hover:text-white transition-colors duration-300 text-center">
                {tech.name}
              </span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function setupTechnologiesTabs() {
    const tabs = document.querySelectorAll("[data-category-tab]");
    const contents = document.querySelectorAll("[data-tech-content]");

    tabs.forEach(tab => {
      tab.addEventListener("click", () => {
        const targetCategory = tab.getAttribute("data-category-tab");

        // Actualizar pestañas activas/inactivas
        tabs.forEach(t => {
          if (t === tab) {
            t.classList.remove("bg-[#0b1c30]/40", "text-on-primary-container/80", "border-outline-variant/20");
            t.classList.add("bg-white", "text-[#0b1c30]", "border-white", "font-bold", "shadow-soft");
          } else {
            t.classList.remove("bg-white", "text-[#0b1c30]", "border-white", "font-bold", "shadow-soft");
            t.classList.add("bg-[#0b1c30]/40", "text-on-primary-container/80", "border-outline-variant/20");
          }
        });

        // Alternar visualización del contenido
        contents.forEach(content => {
          const categoryId = content.getAttribute("data-tech-content");
          if (categoryId === targetCategory) {
            content.classList.remove("opacity-0", "scale-95", "pointer-events-none", "absolute", "inset-0");
            content.classList.add("opacity-100", "scale-100", "pointer-events-auto");
          } else {
            content.classList.remove("opacity-100", "scale-100", "pointer-events-auto");
            content.classList.add("opacity-0", "scale-95", "pointer-events-none", "absolute", "inset-0");
          }
        });
      });
    });
  }

  // Correr en la carga inicial y soporte de transiciones de Astro (si aplica)
  setupTechnologiesTabs();
  document.addEventListener("astro:after-swap", setupTechnologiesTabs);
</script>
