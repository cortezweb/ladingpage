---
---
<section class="py-section-gap bg-surface-container-lowest border-t border-outline-variant/20" id="contacto">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Title Area (Editorial Style) -->
    <div class="flex items-center justify-between border-b border-outline-variant/20 pb-6 mb-16 animate-fade-in">
      <span class="text-xs font-bold uppercase tracking-wider text-primary">CONTACTO & COTIZACIÓN</span>
      <div class="w-10 h-10 rounded-full border border-outline-variant/40 text-on-surface-variant flex items-center justify-center cursor-pointer select-none">
        <span class="material-symbols-outlined text-lg">arrow_downward</span>
      </div>
    </div>

    <!-- Main Profile + CV Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-24">
      
      <!-- Left Column: Portrait + Contacts (5 cols) -->
      <div class="lg:col-span-5 space-y-8 flex flex-col items-center lg:items-start text-center lg:text-left">
        <!-- Portrait Collage -->
        <div class="relative w-full max-w-[340px] aspect-[4/5] flex justify-center items-end">
          <!-- Background Organic shape (Blue/Indigo tint matching palette) -->
          <div class="absolute inset-x-0 bottom-0 top-[20%] bg-primary/10 rounded-t-[40px] rounded-b-[20px] rotate-[-2deg]"></div>
          <!-- Portrait Image -->
          <img 
            src="/team_hamilton.png" 
            alt="Hamilton Cortez" 
            class="relative z-10 w-[85%] h-auto object-cover rounded-t-[30px] rounded-b-[15px] shadow-soft filter grayscale hover:grayscale-0 transition-all duration-500 ease-out"
          />
        </div>

        <!-- Let's Work Together Card (QR + Links) -->
        <div class="w-full max-w-[400px] flex items-center gap-6 bg-surface-bright border border-outline-variant/30 rounded-2xl p-6 shadow-soft text-left">
          <!-- QR Code (SVG Vector) -->
          <div class="w-20 h-20 bg-primary/5 rounded-lg flex items-center justify-center p-2 border border-primary/10 flex-shrink-0">
            <svg class="w-full h-full text-primary" viewBox="0 0 24 24" fill="currentColor">
              <!-- top-left corner -->
              <path d="M2 2h6v6H2V2zm1 1v4h4V3H3z" />
              <path d="M4 4h2v2H4V4z" />
              <!-- top-right corner -->
              <path d="M16 2h6v6h-6V2zm1 1v4h4V3h-4z" />
              <path d="M18 4h2v2h-2V4z" />
              <!-- bottom-left corner -->
              <path d="M2 16h6v6H2v-6zm1 1v4h4v-4H3z" />
              <path d="M4 18h2v2H4v-2z" />
              <!-- random codes -->
              <path d="M10 2h2v2h-2zm4 0h2v2h-2zm-4 4h2v2h-2zm4 0h2v2h-2zm2-2h2v2h-2zm2 2h2v2h-2zm2-4h2v2h-2zm0 4h2v2h-2z" />
              <path d="M10 10h2v2h-2zm0 4h2v2h-2zm0 4h2v2h-2zm4-4h2v2h-2zm0 4h2v2h-2zm2-2h2v2h-2zm2 2h2v2h-2zm2-4h2v2h-2zm0 4h2v2h-2z" />
            </svg>
          </div>

          <!-- Contact list -->
          <div class="space-y-2 flex-grow min-w-0">
            <h4 class="font-headline-md text-sm text-on-surface font-extrabold flex items-start gap-0.5 leading-none">
              <span class="text-primary font-serif">“</span>
              LET'S WORK TOGETHER :
            </h4>
            <div class="space-y-1.5 text-xs text-on-surface-variant font-medium">
              <a href="mailto:hamilton@cortezweb.com" class="flex items-center gap-2 hover:text-primary transition-colors truncate">
                <span class="material-symbols-outlined text-sm text-primary">mail</span>
                hamilton@cortezweb.com
              </a>
              <a href="tel:+51999999999" class="flex items-center gap-2 hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-sm text-primary">call</span>
                +51 999 999 999
              </a>
              <a href="https://linkedin.com" target="_blank" rel="noopener" class="flex items-center gap-2 hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-sm text-primary">share</span>
                linkedin.com/in/hamilton
              </a>
              <a href="https://github.com" target="_blank" rel="noopener" class="flex items-center gap-2 hover:text-primary transition-colors truncate">
                <span class="material-symbols-outlined text-sm text-primary">terminal</span>
                github.com/hamilton
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Profile details (7 cols) -->
      <div class="lg:col-span-7 space-y-10 text-left">
        <!-- Greeting & Bio -->
        <div class="space-y-4">
          <h3 class="font-headline-xl text-3xl sm:text-4xl text-on-surface font-black flex items-start gap-1">
            <span class="text-primary font-serif text-4xl leading-none">“</span>
            HOLA.
          </h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed text-base">
            Soy <strong>Hamilton Cortez</strong>, ingeniero de software y fundador de Cortez Web. Cuento con más de 8 años de experiencia diseñando y programando experiencias digitales de alto rendimiento. Mi filosofía de trabajo combina la rigurosidad técnica, el diseño limpio y una fuerte orientación a resultados comerciales para cada uno de mis clientes.
          </p>
        </div>

        <!-- Education & Skills Block -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 pt-4 border-t border-outline-variant/20">
          <!-- Education (7 cols) -->
          <div class="md:col-span-7 space-y-3">
            <h4 class="font-headline-md text-base text-on-surface font-extrabold border-b border-primary/20 pb-1.5 w-max">
              Educación
            </h4>
            <div class="flex gap-3">
              <span class="font-headline-md text-sm text-primary font-bold">2011-<br/>2015</span>
              <div class="space-y-0.5">
                <h5 class="font-headline-md text-sm text-on-surface font-extrabold">Ingeniería de Software</h5>
                <p class="text-xs text-on-surface-variant font-medium">Universidad Nacional de Ingeniería (UNI)</p>
              </div>
            </div>
          </div>

          <!-- Software Skills (5 cols) -->
          <div class="md:col-span-5 space-y-3">
            <h4 class="font-headline-md text-base text-on-surface font-extrabold border-b border-primary/20 pb-1.5 w-max">
              Software Skills
            </h4>
            <!-- Badges (Ps/Ai Style) -->
            <div class="grid grid-cols-4 gap-2">
              <div class="w-9 h-9 rounded-md bg-[#20232A] text-[#61DAFB] font-black flex items-center justify-center text-xs border border-[#61DAFB]/20 shadow-soft transition-transform hover:scale-105" title="React">Rt</div>
              <div class="w-9 h-9 rounded-md bg-[#FF5A00] text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="Astro">As</div>
              <div class="w-9 h-9 rounded-md bg-black text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="Next.js">Nx</div>
              <div class="w-9 h-9 rounded-md bg-[#339933] text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="Node.js">Nd</div>
              <div class="w-9 h-9 rounded-md bg-[#3178C6] text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="TypeScript">Ts</div>
              <div class="w-9 h-9 rounded-md bg-[#336791] text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="PostgreSQL">Pg</div>
              <div class="w-9 h-9 rounded-md bg-[#007ACC] text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="VS Code">Vs</div>
              <div class="w-9 h-9 rounded-md bg-[#F24E1E] text-white font-black flex items-center justify-center text-xs border border-white/5 shadow-soft transition-transform hover:scale-105" title="Figma">Fi</div>
            </div>
          </div>
        </div>

        <!-- Working Experience Block -->
        <div class="pt-6 border-t border-outline-variant/20 space-y-4">
          <h4 class="font-headline-md text-base text-on-surface font-extrabold border-b border-primary/20 pb-1.5 w-max">
            Experiencia Laboral
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 text-xs">
            <div class="flex gap-3 border-l-2 border-primary/20 pl-3">
              <div class="space-y-1">
                <h5 class="font-headline-md text-sm text-on-surface font-extrabold">Lead Frontend Developer</h5>
                <p class="text-on-surface-variant font-medium">Cortez Web • 2021 - Presente</p>
              </div>
            </div>
            <div class="flex gap-3 border-l-2 border-primary/20 pl-3">
              <div class="space-y-1">
                <h5 class="font-headline-md text-sm text-on-surface font-extrabold">Senior Software Engineer</h5>
                <p class="text-on-surface-variant font-medium">Tech Solutions • 2018 - 2021</p>
              </div>
            </div>
            <div class="flex gap-3 border-l-2 border-primary/20 pl-3">
              <div class="space-y-1">
                <h5 class="font-headline-md text-sm text-on-surface font-extrabold">Full Stack Developer</h5>
                <p class="text-on-surface-variant font-medium">Digital Agency • 2015 - 2018</p>
              </div>
            </div>
            <div class="flex gap-3 border-l-2 border-primary/20 pl-3">
              <div class="space-y-1">
                <h5 class="font-headline-md text-sm text-on-surface font-extrabold">Consultor Técnico</h5>
                <p class="text-on-surface-variant font-medium">Freelance • 2015 - Presente</p>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- Quotation Form Container (Part 2) -->
    <div class="mt-20 border-t border-outline-variant/20 pt-16">
      <div class="text-center mb-12 animate-fade-in">
        <h2 class="font-headline-xl text-3xl sm:text-4xl text-on-surface mb-3">Iniciar Cotización de Proyecto</h2>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto text-sm sm:text-base">
          Completa el formulario y Hamilton se pondrá en contacto contigo muy pronto para conversar sobre tu proyecto.
        </p>
      </div>

      <div class="bg-surface-bright border border-outline-variant/30 rounded-2xl p-8 md:p-12 shadow-soft">
        <form class="space-y-6">
          <!-- Honeypot Field for Spam Protection -->
          <div class="hidden" aria-hidden="true">
            <label for="honeypot-input">Leave this field blank</label>
            <input 
              id="honeypot-input" 
              type="text" 
              name="honeypot" 
              tabindex="-1" 
              autocomplete="off"
            />
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="font-label-md text-label-md text-on-surface">Nombre Completo</label>
              <input 
                id="name-input"
                class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md" 
                placeholder="Tu nombre" 
                type="text"
                required
              />
            </div>
            <div class="space-y-2">
              <label class="font-label-md text-label-md text-on-surface">Correo Electrónico</label>
              <input 
                id="email-input"
                class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md" 
                placeholder="tu@email.com" 
                type="email"
                required
              />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="font-label-md text-label-md text-on-surface">Número de Celular / WhatsApp</label>
              <input 
                id="phone-input"
                class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md" 
                placeholder="+51 999 999 999" 
                type="tel"
                required
              />
            </div>
            <div class="space-y-2">
              <label class="font-label-md text-label-md text-on-surface">Tipo de Proyecto</label>
              <select 
                id="type-select"
                class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md"
              >
                <option value="web">Desarrollo Web</option>
                <option value="mobile">App Móvil</option>
                <option value="pos">Sistemas POS</option>
                <option value="ecommerce">E-commerce</option>
              </select>
            </div>
          </div>
          <div class="space-y-2">
            <label class="font-label-md text-label-md text-on-surface">Descripción del Proyecto</label>
            <textarea 
              id="desc-textarea"
              class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md" 
              placeholder="Cuéntanos brevemente sobre tu idea..." 
              rows="4"
              required
            ></textarea>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <button 
              class="flex-1 bg-primary-container text-on-primary font-label-md text-label-md px-8 py-4 rounded-lg hover:bg-primary transition-colors shadow-soft flex items-center justify-center gap-2 cursor-pointer active:scale-98" 
              type="submit"
            >
              Enviar Solicitud
              <span class="material-symbols-outlined">send</span>
            </button>
            <a 
              id="whatsapp-btn"
              class="flex-1 border-2 border-[#25D366] text-[#25D366] font-label-md text-label-md px-8 py-4 rounded-lg hover:bg-[#25D366] hover:text-white transition-all flex items-center justify-center gap-2 cursor-pointer select-none active:scale-98" 
              href="#"
              target="_blank"
            >
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.431 5.63 1.432h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
              </svg>
              Agendar por WhatsApp
            </a>
          </div>
        </form>
      </div>
    </div>

  </div>
</section>

<!-- Success Modal Overlay -->
<div id="success-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 opacity-0 pointer-events-none transition-all duration-300">
  <div class="bg-surface border border-outline-variant/30 rounded-2xl p-8 w-[90%] max-w-[450px] mx-auto shadow-elevated text-center space-y-6 transform scale-95 transition-transform duration-300" id="success-modal-content">
    <div class="w-16 h-16 bg-primary/10 text-primary rounded-full flex items-center justify-center mx-auto">
      <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
    </div>
    <div class="space-y-2">
      <h3 class="font-headline-md text-headline-md text-on-surface">¡Solicitud Recibida!</h3>
      <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed font-normal">
        Gracias por ponerte en contacto. Hamilton se comunicará contigo muy pronto para conversar sobre tu proyecto.
      </p>
    </div>
    <button id="close-modal-btn" class="w-full bg-primary-container text-on-primary font-label-md text-label-md py-3 rounded-lg hover:bg-primary transition-colors cursor-pointer active:scale-98">
      Excelente
    </button>
  </div>
</div>

<script>
  const form = document.querySelector('#contacto form') as HTMLFormElement;
  const whatsappBtn = document.getElementById('whatsapp-btn') as HTMLAnchorElement;
  const successModal = document.getElementById('success-modal') as HTMLDivElement;
  const successModalContent = document.getElementById('success-modal-content') as HTMLDivElement;
  const closeModalBtn = document.getElementById('close-modal-btn') as HTMLButtonElement;

  // Function to build WhatsApp link dynamically with input fields
  function updateWhatsAppLink() {
    const name = (document.getElementById('name-input') as HTMLInputElement)?.value || '';
    const email = (document.getElementById('email-input') as HTMLInputElement)?.value || '';
    const phone = (document.getElementById('phone-input') as HTMLInputElement)?.value || '';
    const typeSelect = document.getElementById('type-select') as HTMLSelectElement;
    const typeText = typeSelect?.options[typeSelect.selectedIndex]?.text || '';
    const desc = (document.getElementById('desc-textarea') as HTMLTextAreaElement)?.value || '';

    // Fixed WhatsApp Number for Hamilton
    const targetPhone = '51999999999'; 
    const message = `Hola Hamilton, mi nombre es ${name}. Me gustaría cotizar un proyecto de ${typeText}.\n\nMis datos de contacto:\n- Correo: ${email}\n- Teléfono: ${phone}\n\nDescripción del proyecto:\n${desc}`;
    
    whatsappBtn.href = `https://wa.me/${targetPhone}?text=${encodeURIComponent(message)}`;
  }

  // Update link on input changes
  const inputIds = ['name-input', 'email-input', 'phone-input', 'type-select', 'desc-textarea'];
  inputIds.forEach(id => {
    document.getElementById(id)?.addEventListener('input', updateWhatsAppLink);
  });
  document.getElementById('type-select')?.addEventListener('change', updateWhatsAppLink);

  // Initial update
  updateWhatsAppLink();

  // Intercept Form Submit
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Honeypot spam check
    const honeypot = (document.getElementById('honeypot-input') as HTMLInputElement)?.value;
    if (honeypot) {
      console.warn('Spam submission detected and blocked.');
      form.reset();
      updateWhatsAppLink();
      return;
    }

    if (form.checkValidity()) {
      // Show Modal
      successModal.classList.remove('opacity-0', 'pointer-events-none');
      successModalContent.classList.remove('scale-95');
      successModalContent.classList.add('scale-100');
      form.reset();
      updateWhatsAppLink();
    }
  });

  // Close Modal
  closeModalBtn?.addEventListener('click', () => {
    successModal.classList.add('opacity-0', 'pointer-events-none');
    successModalContent.classList.remove('scale-100');
    successModalContent.classList.add('scale-95');
  });
</script>
