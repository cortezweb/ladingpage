---
// src/components/Footer.astro
---

<footer class="bg-surface-bright border-t border-outline-variant/20 w-full mt-20 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6 flex flex-col gap-12">
    
    <!-- Fila Superior: Newsletter -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8 lg:gap-16 pb-12 border-b border-outline-variant/20">
      <div class="lg:max-w-xl flex-1">
        <h3 class="font-headline-lg text-headline-lg text-on-surface mb-2">
          Suscríbete a nuestro <span class="text-primary">Newsletter</span>
        </h3>
        <p class="font-body-md text-body-md text-on-surface-variant">
          Recibe contenido exclusivo sobre desarrollo web moderno, optimización de rendimiento y diseño de producto.
        </p>
      </div>
      <form class="w-full lg:max-w-md shrink-0 flex flex-col sm:flex-row gap-3 relative">
        <div class="relative w-full">
          <input 
            type="email" 
            placeholder="Introduce tu correo electrónico" 
            required
            class="w-full px-6 py-4 rounded-full bg-surface-container border border-outline-variant/30 text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:border-primary/50 font-body-md text-body-md"
          />
        </div>
        <button 
          type="submit" 
          class="px-8 py-4 bg-primary text-white font-label-md text-label-md rounded-full hover:bg-primary-container transition-all duration-300 shadow-soft cursor-pointer whitespace-nowrap"
        >
          Suscribirse
        </button>
      </form>
    </div>

    <!-- Fila Central: Grilla de Enlaces -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10">
      
      <!-- Columna 1: Info Marca (4 cols) -->
      <div class="lg:col-span-4 flex flex-col gap-6">
        <span class="text-headline-md font-headline-md text-on-surface font-black">
          Cortez Web
        </span>
        <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed max-w-sm">
          Creamos experiencias digitales y aplicaciones web de alto rendimiento orientadas a la conversión y la excelencia visual.
        </p>
        <div class="flex items-center gap-3">
          <!-- LinkedIn -->
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-white transition-all duration-300" aria-label="LinkedIn">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
          <!-- GitHub -->
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-white transition-all duration-300" aria-label="GitHub">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <!-- Twitter / X -->
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-white transition-all duration-300" aria-label="Twitter">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </a>
          <!-- Dribbble -->
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-white transition-all duration-300" aria-label="Dribbble">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.777-2.525-4.872-6.509-3.345.176.43.346.862.504 1.297 3.952-.397 5.823 1.745 6.005 2.048.24-.805.384-1.656.384-2.532v-.039-1.429zm-1.849 5.093c-.097-.21-1.742-3.412-5.719-2.247-.417.842-.816 1.696-1.18 2.559 3.036 1.328 5.617 1.542 6.012.392.384-.903.687-1.859.887-2.704zm-8.324 3.738c-.378-1.503-.984-3.504-2.023-5.263-1.636.568-4.484 2.112-5.064 4.542 1.654 1.353 3.766 2.15 6.069 2.15.342 0 .681-.027 1.018-.079v-1.35zm-8.212-6.861c.42-.047 3.968-.507 6.467-2.148-.521-.926-1.077-1.884-1.656-2.825-3.036.985-5.38 3.863-5.38 3.863v.35c.168.261.357.514.569.76zm2.348-7.531c2.195-2.091 5.378-1.921 5.378-1.921-.088.358-.871 3.255-2.164 5.347-2.083-.717-3.921-2.906-4.225-3.426.31-.383.65-.729 1.011-1.036v.036zm8.811-1.121c.063.153.86 2.215.176 5.334 2.825-.991 4.582-3.013 4.582-3.013s-2.062-1.983-4.758-2.321z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columna 2: Servicios (2 cols) -->
      <div class="lg:col-span-2 lg:ml-auto flex flex-col gap-6">
        <h4 class="font-label-md text-label-md text-primary tracking-wider uppercase font-bold">
          Servicios
        </h4>
        <ul class="flex flex-col gap-3 font-body-md text-body-md">
          <li>
            <a href="#services" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Desarrollo Web
            </a>
          </li>
          <li>
            <a href="#services" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Aplicaciones Móviles
            </a>
          </li>
          <li>
            <a href="#services" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Plataformas E-commerce
            </a>
          </li>
          <li>
            <a href="#services" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Sistemas POS
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 3: Compañía (2 cols) -->
      <div class="lg:col-span-2 lg:ml-auto flex flex-col gap-6">
        <h4 class="font-label-md text-label-md text-primary tracking-wider uppercase font-bold">
          Compañía
        </h4>
        <ul class="flex flex-col gap-3 font-body-md text-body-md">
          <li>
            <a href="#" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Inicio
            </a>
          </li>
          <li>
            <a href="#portfolio" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Portafolio
            </a>
          </li>
          <li>
            <a href="#team" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Sobre Mí
            </a>
          </li>
          <li>
            <a href="#blog" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Blog
            </a>
          </li>
          <li>
            <a href="#contact" class="text-on-surface-variant hover:text-primary transition-colors duration-200">
              Contacto
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Contacto (4 cols) -->
      <div class="lg:col-span-4 lg:ml-auto flex flex-col gap-6">
        <h4 class="font-label-md text-label-md text-primary tracking-wider uppercase font-bold">
          Contacto
        </h4>
        <ul class="flex flex-col gap-4 font-body-md text-body-md text-on-surface-variant">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary mt-0.5">location_on</span>
            <span>Surat, Gujarat, India (Remoto / Global)</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">mail</span>
            <a href="mailto:hamilton.cortez@example.com" class="hover:text-primary transition-colors duration-200">
              hamilton.cortez@example.com
            </a>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">call</span>
            <a href="tel:+1234567890" class="hover:text-primary transition-colors duration-200">
              +1 (234) 567-890
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Fila Inferior: Copyright -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 pt-8 border-t border-outline-variant/20 font-label-md text-label-md text-on-surface-variant/80">
      <div>
        © 2026 Cortez Web. Todos los derechos reservados.
      </div>
      <div>
        Hecho con ♥ por <span class="text-primary font-bold">Cortez Web</span>
      </div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-primary transition-colors duration-200">
          Política de Privacidad
        </a>
        <a href="#" class="hover:text-primary transition-colors duration-200">
          Términos de Servicio
        </a>
      </div>
    </div>

  </div>
</footer>
