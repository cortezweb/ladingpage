---
---
<section class="py-12 relative w-full">
  <!-- Glowing background elements -->
  <div class="absolute -top-40 left-1/3 w-96 h-96 bg-primary/10 blur-[120px] rounded-full pointer-events-none"></div>
  <div class="absolute top-20 right-10 w-80 h-80 bg-primary/5 blur-[100px] rounded-full pointer-events-none"></div>

  <!-- Header Intro Area -->
  <div class="max-w-4xl mx-auto text-center space-y-6 mb-16 animate-fade-in">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container border border-outline-variant/30 text-primary text-xs font-semibold">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      Disponibilidad Inmediata
    </div>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight text-on-surface">
      Ingeniería Web de <span class="gradient-text">Alto Nivel.</span>
    </h1>
    
    <div class="flex flex-wrap gap-4 pt-2 justify-center">
      <a href="#contacto" class="bg-primary-container text-on-primary font-semibold text-sm px-8 py-4 rounded-lg hover:-translate-y-0.5 active:translate-y-0 transition-all shadow-soft flex items-center justify-center gap-2 cursor-pointer text-center">
        Iniciar Proyecto
        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 0;">arrow_forward</span>
      </a>
      <a href="#portafolio" class="border border-outline-variant text-on-surface font-semibold text-sm px-8 py-4 rounded-lg hover:border-primary hover:text-primary hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 cursor-pointer text-center">
        Ver Portafolio
      </a>
    </div>
  </div>

  <!-- Giant Showcase Carousel Banner -->
  <div class="w-full relative bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden shadow-elevated text-white min-h-[700px] sm:min-h-[620px] lg:min-h-[660px] xl:min-h-[700px] flex items-center animate-fade-in">
    <!-- Overlay subtle background pattern -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-slate-900 via-slate-950 to-black pointer-events-none"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-5 pointer-events-none"></div>

    <!-- Slides Container -->
    <div class="relative w-full h-full" id="carousel-slides">
      
      <!-- Slide 1: E-commerce -->
      <div class="carousel-slide absolute inset-0 opacity-100 transition-all duration-700 ease-in-out p-8 py-10 sm:py-12 sm:px-16 lg:py-12 lg:px-24 xl:px-28 xl:py-16 flex flex-col lg:flex-row items-center gap-10 justify-between z-10">
        <!-- Left info -->
        <div class="w-full lg:w-[48%] space-y-4 text-left flex flex-col justify-center h-full">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-primary/20 border border-primary/30 text-primary text-[10px] font-bold uppercase tracking-wider w-max">
            SOLUCIÓN COMERCIAL
          </div>
          <h3 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
            E-Commerce Premium & Headless
          </h3>
          <p class="text-base lg:text-lg text-gray-300 font-normal leading-relaxed">
            Tiendas virtuales de alto rendimiento optimizadas para la máxima tasa de conversión. Velocidad de carga inferior a 1 segundo, arquitectura headless moderna y paneles autoadministrables robustos.
          </p>
          <ul class="space-y-3 text-sm lg:text-base text-gray-400">
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Carga instantánea y posicionamiento SEO estratégico
            </li>
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Pasarelas Stripe, PayPal y transferencias integradas
            </li>
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Panel de control ágil para gestionar catálogo e inventario
            </li>
          </ul>
          <div class="flex gap-2 pt-2 flex-wrap">
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">React</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Astro</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Stripe</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Tailwind CSS</span>
          </div>
          <div class="pt-4">
            <button data-project="ecommerce" class="carousel-cta-btn bg-primary hover:bg-primary/95 text-white font-bold text-base px-8 py-4 rounded-lg hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center justify-center gap-2 cursor-pointer shadow-soft">
              Cotizar E-Commerce
              <span class="material-symbols-outlined text-lg">payments</span>
            </button>
          </div>
        </div>
        <!-- Right Image Mockup -->
        <div class="hidden sm:flex w-full lg:w-[48%] justify-center items-center">
          <div class="relative w-full max-w-[480px] lg:max-w-[580px] aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-slate-950/40 p-2 group hover:scale-102 transition-all duration-500">
            <img src="/ecommerce_mockup.png" alt="E-Commerce Premium" class="w-full h-full object-cover rounded-xl" />
          </div>
        </div>
      </div>

      <!-- Slide 2: POS -->
      <div class="carousel-slide absolute inset-0 opacity-0 transition-all duration-700 ease-in-out pointer-events-none p-8 py-10 sm:py-12 sm:px-16 lg:py-12 lg:px-24 xl:px-28 xl:py-16 flex flex-col lg:flex-row items-center gap-10 justify-between z-10">
        <!-- Left info -->
        <div class="w-full lg:w-[48%] space-y-4 text-left flex flex-col justify-center h-full">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-primary/20 border border-primary/30 text-primary text-[10px] font-bold uppercase tracking-wider w-max">
            SISTEMA EMPRESARIAL
          </div>
          <h3 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
            POS & Dashboard Cloud
          </h3>
          <p class="text-base lg:text-lg text-gray-300 font-normal leading-relaxed">
            Control total de tu negocio desde cualquier lugar. Facturación electrónica inmediata, reportes avanzados de ventas, control de existencias en tiempo real y gestión segura multi-sucursal.
          </p>
          <ul class="space-y-3 text-sm lg:text-base text-gray-400">
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Facturación electrónica integrada con normativas locales
            </li>
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Control de inventario inteligente y alertas de stock bajo
            </li>
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Dashboard analítico con gráficos interactivos y descargas
            </li>
          </ul>
          <div class="flex gap-2 pt-2 flex-wrap">
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Vue.js</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Node.js</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">PostgreSQL</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">REST API</span>
          </div>
          <div class="pt-4">
            <button data-project="pos" class="carousel-cta-btn bg-primary hover:bg-primary/95 text-white font-bold text-base px-8 py-4 rounded-lg hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center justify-center gap-2 cursor-pointer shadow-soft">
              Cotizar Sistema POS
              <span class="material-symbols-outlined text-lg">point_of_sale</span>
            </button>
          </div>
        </div>
        <!-- Right Image Mockup -->
        <div class="hidden sm:flex w-full lg:w-[48%] justify-center items-center">
          <div class="relative w-full max-w-[480px] lg:max-w-[580px] aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-slate-950/40 p-2 group hover:scale-102 transition-all duration-500">
            <img src="/pos_mockup.png" alt="POS Cloud Dashboard" class="w-full h-full object-cover rounded-xl" />
          </div>
        </div>
      </div>

      <!-- Slide 3: Uber Clone -->
      <div class="carousel-slide absolute inset-0 opacity-0 transition-all duration-700 ease-in-out pointer-events-none p-8 py-10 sm:py-12 sm:px-16 lg:py-12 lg:px-24 xl:px-28 xl:py-16 flex flex-col lg:flex-row items-center gap-10 justify-between z-10">
        <!-- Left info -->
        <div class="w-full lg:w-[48%] space-y-4 text-left flex flex-col justify-center h-full">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-primary/20 border border-primary/30 text-primary text-[10px] font-bold uppercase tracking-wider w-max">
            PRODUCTO MÓVIL
          </div>
          <h3 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
            App Móvil de Rutas & Tracking
          </h3>
          <p class="text-base lg:text-lg text-gray-300 font-normal leading-relaxed">
            Solución móvil de logística inteligente. Geolocalización satelital en tiempo real, trazado interactivo de rutas GPS, notificaciones push automáticas y pagos integrados seguros.
          </p>
          <ul class="space-y-3 text-sm lg:text-base text-gray-400">
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Geolocalización precisa con Google Maps / Mapbox
            </li>
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Notificaciones instantáneas para usuarios y proveedores
            </li>
            <li class="flex items-center gap-2.5">
              <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
              Pasarelas de cobro in-app optimizadas (card / apple / google)
            </li>
          </ul>
          <div class="flex gap-2 pt-2 flex-wrap">
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">React Native</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Firebase</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">Google Maps API</span>
            <span class="px-3 py-1.5 bg-white/10 text-white rounded-md text-xs font-semibold">iOS & Android</span>
          </div>
          <div class="pt-4">
            <button data-project="mobile" class="carousel-cta-btn bg-primary hover:bg-primary/95 text-white font-bold text-base px-8 py-4 rounded-lg hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center justify-center gap-2 cursor-pointer shadow-soft">
              Cotizar App Móvil
              <span class="material-symbols-outlined text-lg">directions_car</span>
            </button>
          </div>
        </div>
        <!-- Right Image Mockup -->
        <div class="hidden sm:flex w-full lg:w-[48%] justify-center items-center">
          <div class="relative w-full max-w-[480px] lg:max-w-[580px] aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-slate-950/40 p-2 group hover:scale-102 transition-all duration-500">
            <img src="/uber_mockup.png" alt="App Móvil Uber Clone" class="w-full h-full object-cover rounded-xl" />
          </div>
        </div>
      </div>

    </div>

    <!-- Navigation Arrows -->
    <button id="carousel-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/20 cursor-pointer select-none z-20 backdrop-blur-md transition-all border border-white/10 active:scale-90">
      <span class="material-symbols-outlined text-2xl">chevron_left</span>
    </button>
    <button id="carousel-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/20 cursor-pointer select-none z-20 backdrop-blur-md transition-all border border-white/10 active:scale-90">
      <span class="material-symbols-outlined text-2xl">chevron_right</span>
    </button>

    <!-- Indicators -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2.5 z-20 items-center">
      <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-white/40 hover:bg-white transition-all cursor-pointer" data-slide="0"></button>
      <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-white/40 hover:bg-white transition-all cursor-pointer" data-slide="1"></button>
      <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-white/40 hover:bg-white transition-all cursor-pointer" data-slide="2"></button>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  let currentIndex = 0;
  let intervalId: any = null;

  function showSlide(index: number) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.remove('opacity-0', 'pointer-events-none');
        slide.classList.add('opacity-100');
      } else {
        slide.classList.remove('opacity-100');
        slide.classList.add('opacity-0', 'pointer-events-none');
      }
    });

    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.remove('bg-white/40');
        dot.classList.add('bg-white', 'w-6');
      } else {
        dot.classList.remove('bg-white', 'w-6');
        dot.classList.add('bg-white/40');
      }
    });

    currentIndex = index;
  }

  function nextSlide() {
    let nextIndex = (currentIndex + 1) % slides.length;
    showSlide(nextIndex);
  }

  function prevSlide() {
    let prevIndex = (currentIndex - 1 + slides.length) % slides.length;
    showSlide(prevIndex);
  }

  // Set autoplay to 5 seconds
  function startAutoplay() {
    stopAutoplay();
    intervalId = setInterval(nextSlide, 5000);
  }

  function stopAutoplay() {
    if (intervalId) clearInterval(intervalId);
  }

  // Event Listeners for Nav
  prevBtn?.addEventListener('click', () => {
    prevSlide();
    startAutoplay();
  });

  nextBtn?.addEventListener('click', () => {
    nextSlide();
    startAutoplay();
  });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      showSlide(i);
      startAutoplay();
    });
  });

  // Pause on hover
  const carouselContainer = document.querySelector('.w-full.relative.bg-slate-900');
  carouselContainer?.addEventListener('mouseenter', stopAutoplay);
  carouselContainer?.addEventListener('mouseleave', startAutoplay);

  // Form link integration
  const ctaButtons = document.querySelectorAll('.carousel-cta-btn');
  ctaButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const projectType = btn.getAttribute('data-project');
      const select = document.getElementById('type-select') as HTMLSelectElement;
      const descTextarea = document.getElementById('desc-textarea') as HTMLTextAreaElement;
      const nameInput = document.getElementById('name-input') as HTMLInputElement;

      if (select) {
        if (projectType === 'ecommerce') select.value = 'ecommerce';
        else if (projectType === 'pos') select.value = 'pos';
        else if (projectType === 'mobile') select.value = 'mobile';
        
        // Trigger select change event for WhatsApp link updating
        select.dispatchEvent(new Event('change'));
      }

      if (descTextarea) {
        if (projectType === 'ecommerce') {
          descTextarea.value = "Hola Hamilton, me interesa cotizar una plataforma de E-Commerce Premium. Quisiera saber más sobre los costos y tiempos de entrega.";
        } else if (projectType === 'pos') {
          descTextarea.value = "Hola Hamilton, estoy interesado en un Sistema POS Cloud para mi negocio. Me gustaría programar una demo y conocer las opciones.";
        } else if (projectType === 'mobile') {
          descTextarea.value = "Hola Hamilton, me gustaría cotizar el desarrollo de una App Móvil con rutas y geolocalización. Deseo recibir más detalles.";
        }
        // Trigger textarea input event for WhatsApp link updating
        descTextarea.dispatchEvent(new Event('input'));
      }

      // Scroll to contact form smoothly
      const contactSection = document.getElementById('contacto');
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: 'smooth' });
      }

      // Focus name field
      if (nameInput) {
        setTimeout(() => {
          nameInput.focus();
        }, 800); // Wait for scroll animation to complete
      }
    });
  });

  // Init
  showSlide(0);
  startAutoplay();
</script>
