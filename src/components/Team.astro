---
const team = [
  {
    name: "Hamilton Cortez",
    role: "Fundador & Director de Tecnología (CTO)",
    bio: "Especialista en arquitecturas frontend escalables con React y Astro, con más de 8 años de experiencia liderando proyectos web de alto rendimiento.",
    image: "/team_hamilton.png",
    socials: {
      linkedin: "https://linkedin.com",
      github: "https://github.com",
      twitter: "https://twitter.com"
    }
  },
  {
    name: "Sofía Álvarez",
    role: "Co-Fundadora & Directora de UX/UI",
    bio: "Apasionada por crear interfaces intuitivas, sistemas de diseño dinámicos y experiencias de usuario que conecten emocionalmente con las personas.",
    image: "/team_sofia.png",
    socials: {
      linkedin: "https://linkedin.com",
      github: "https://github.com",
      twitter: "https://twitter.com"
    }
  },
  {
    name: "Mateo Silva",
    role: "Director de Ingeniería Backend",
    bio: "Experto en diseño de APIs RESTful, bases de datos relacionales y soluciones en la nube de alta disponibilidad y seguridad avanzada.",
    image: "/team_mateo.png",
    socials: {
      linkedin: "https://linkedin.com",
      github: "https://github.com",
      twitter: "https://twitter.com"
    }
  }
];
---

<section class="py-section-gap bg-surface-container-lowest border-t border-outline-variant/20" id="equipo">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto space-y-4 animate-fade-in">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container border border-outline-variant/30 text-primary text-xs font-semibold">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        Nuestro ADN
      </div>
      <h2 class="font-headline-xl text-headline-xl text-on-surface">
        Liderazgo & <span class="gradient-text">Visión.</span>
      </h2>
      <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto">
        El equipo detrás de Cortez Web, dedicados a llevar la ingeniería y el diseño web al siguiente nivel con pasión y rigurosidad técnica.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {team.map((member) => (
        <div class="group bg-surface-bright border border-outline-variant/30 rounded-2xl p-8 shadow-soft hover:shadow-elevated transition-all duration-300 flex flex-col items-center text-center hover:-translate-y-1">
          <!-- Avatar Container -->
          <div class="relative w-40 h-40 rounded-full overflow-hidden border-2 border-primary/10 group-hover:border-primary transition-all duration-300 shadow-soft mb-6">
            <img 
              src={member.image} 
              alt={`Retrato profesional de ${member.name}`} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>

          <!-- Name & Role -->
          <div class="space-y-1">
            <h3 class="font-headline-md text-headline-md text-on-surface group-hover:text-primary transition-colors">
              {member.name}
            </h3>
            <span class="inline-block text-[10px] font-bold uppercase tracking-wider text-primary bg-primary/10 border border-primary/20 px-3.5 py-1.5 rounded-full w-max mt-2 mb-4">
              {member.role}
            </span>
          </div>

          <!-- Bio -->
          <p class="font-body-md text-body-md text-on-surface-variant text-sm leading-relaxed mt-2 flex-grow">
            {member.bio}
          </p>

          <!-- Socials Link -->
          <div class="flex gap-4 pt-6 mt-auto">
            <a href={member.socials.linkedin} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-outline-variant/40 text-on-surface-variant hover:text-primary hover:border-primary flex items-center justify-center transition-colors active:scale-90" aria-label={`Ver perfil de LinkedIn de ${member.name}`}>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </a>
            <a href={member.socials.github} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-outline-variant/40 text-on-surface-variant hover:text-primary hover:border-primary flex items-center justify-center transition-colors active:scale-90" aria-label={`Ver perfil de GitHub de ${member.name}`}>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a href={member.socials.twitter} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-outline-variant/40 text-on-surface-variant hover:text-primary hover:border-primary flex items-center justify-center transition-colors active:scale-90" aria-label={`Ver perfil de Twitter de ${member.name}`}>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
